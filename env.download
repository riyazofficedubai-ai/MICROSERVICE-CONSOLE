'use client';

import Link from 'next/link';
import { Box, Container, Typography, Stack, Button, Paper, Chip } from '@mui/material';
import ArrowForwardIcon from '@mui/icons-material/ArrowForward';
import { monoFont } from '@/lib/theme';

const cards = [
  {
    href: '/signup',
    eyebrow: 'JSON-DRIVEN',
    title: 'Signup Form',
    description:
      'A form rendered entirely from a field-definition JSON array — change a fieldType from TEXT to LIST or RADIO and the UI swaps instantly.',
  },
  {
    href: '/products',
    eyebrow: 'PRODUCT SERVICE · :3001',
    title: 'Products',
    description:
      'Create, browse, and manage product inventory — the source of truth the Order Service queries over TCP.',
  },
  {
    href: '/orders',
    eyebrow: 'ORDER SERVICE · :3002',
    title: 'Orders',
    description:
      'Place orders against live product stock. Each order snapshot pulls product details via inter-service communication.',
  },
];

export default function HomePage() {
  return (
    <Box sx={{ bgcolor: 'background.default', minHeight: '100vh' }}>
      <Container maxWidth="lg" sx={{ pt: { xs: 6, md: 10 }, pb: 8 }}>
        <Stack spacing={2} sx={{ maxWidth: 720, mb: 7 }}>
          <Chip
            label="MICROSERVICE CONSOLE"
            size="small"
            sx={{
              alignSelf: 'flex-start',
              bgcolor: 'secondary.main',
              color: 'secondary.contrastText',
              fontFamily: monoFont,
              letterSpacing: '0.04em',
            }}
          />
          <Typography variant="h2" sx={{ fontSize: { xs: '2rem', md: '2.75rem' } }}>
            Two services, one manifest.
          </Typography>
          <Typography variant="body1" color="text.secondary" sx={{ fontSize: '1.05rem' }}>
            A Product Service and an Order Service talk to each other over TCP to validate
            stock and assemble orders. The client below renders forms straight from JSON —
            no hardcoded fields, no rebuilds for schema changes.
          </Typography>
        </Stack>

        <Stack
          direction={{ xs: 'column', md: 'row' }}
          spacing={3}
          sx={{ alignItems: 'stretch' }}
        >
          {cards.map((card) => (
            <Paper
              key={card.href}
              component={Link}
              href={card.href}
              elevation={0}
              sx={{
                flex: 1,
                p: 3.5,
                textDecoration: 'none',
                border: '1px solid',
                borderColor: 'divider',
                transition: 'border-color 0.15s ease, transform 0.15s ease',
                '&:hover': {
                  borderColor: 'secondary.main',
                  transform: 'translateY(-2px)',
                },
              }}
            >
              <Typography
                variant="caption"
                sx={{
                  fontFamily: monoFont,
                  color: 'secondary.dark',
                  letterSpacing: '0.05em',
                  fontWeight: 600,
                }}
              >
                {card.eyebrow}
              </Typography>
              <Typography variant="h5" sx={{ mt: 1, mb: 1, color: 'text.primary' }}>
                {card.title}
              </Typography>
              <Typography variant="body2" color="text.secondary" sx={{ mb: 2 }}>
                {card.description}
              </Typography>
              <Stack direction="row" alignItems="center" spacing={0.5} sx={{ color: 'primary.main' }}>
                <Typography variant="button" fontWeight={600}>
                  Open
                </Typography>
                <ArrowForwardIcon fontSize="small" />
              </Stack>
            </Paper>
          ))}
        </Stack>
      </Container>
    </Box>
  );
}
